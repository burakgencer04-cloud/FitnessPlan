rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Sadece giriş yapmış kullanıcılar okuyabilir
    // Sadece kendi ID'si ile eşleşen dökümanları oluşturabilir/silebilir
    match /feed/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    match /marketplace/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.authorId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.authorId;
    }

    // Co-op (eşli) antrenman odalarına sadece giriş yapanlar erişebilir
    match /coop_sessions/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}